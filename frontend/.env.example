# Frontend Next.js - Variables d'Environnement
# Copiez ce fichier vers .env.local pour le développement local

# ============================================
# API Backend
# ============================================
# URL du backend API (obligatoire en production)
NEXT_PUBLIC_API_BASE_URL=http://localhost:10000
# Alternative: NEXT_PUBLIC_API_URL (utilisé si NEXT_PUBLIC_API_BASE_URL n'est pas défini)

# ============================================
# Site URL
# ============================================
# URL publique du site (pour métadonnées Open Graph, etc.)
# En développement: http://localhost:3000
# En production: https://votre-domaine.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Environnement
# ============================================
# Ne PAS modifier manuellement - géré automatiquement par Next.js
# NODE_ENV=development (développement) ou production (production)

# ============================================
# Sentry (monitoring des erreurs)
# ============================================
# DSN public - visible côté client (https://sentry.io)
# Crée un projet Next.js sur sentry.io puis copie le DSN
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# SENTRY_RELEASE=git-sha-du-deploiement
# NEXT_PUBLIC_SENTRY_RELEASE=git-sha-du-deploiement
# Optionnel - pour l'upload des source maps (CI) :
# SENTRY_ORG=ton-org
# SENTRY_PROJECT=mathakine-frontend
# SENTRY_AUTH_TOKEN=sntrys_xxx

# ============================================
# Playwright E2E (optionnel, futurs lots)
# ============================================
# Le lot minimal E2E (__tests__/e2e) n’utilise pas de compte seed ni de fichier d’auth Playwright.
# Variables dédiées auth/session pourront être documentées avec un lot E2E séparé.

# ============================================
# Notes
# ============================================
# - Ne jamais commiter .env.local avec des secrets
# - En production, définir ces variables dans votre plateforme de déploiement
# - NEXT_PUBLIC_* variables sont exposées au client (ne pas mettre de secrets)
# - Pour les secrets backend, utiliser les variables d'environnement du serveur
