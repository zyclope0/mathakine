# Frontend Next.js - Variables d'environnement
# Copier ce fichier vers .env.local pour le developpement local

# ============================================
# Next.js runtime serveur (session / JWT local)
# ============================================
# Secret partage avec le backend pour valider localement les JWT (cookie access_token)
# lors du routage protege cote Next (`lib/auth/server/routeSession.ts`).
# Utiliser la meme valeur que SECRET_KEY cote backend Python.
# Ne jamais exposer cette variable en NEXT_PUBLIC_*.
# SECRET_KEY=your-backend-secret-key

# ============================================
# API Backend
# ============================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:10000
# Alternative legacy encore acceptee :
# NEXT_PUBLIC_API_URL=http://localhost:10000

# ============================================
# Site URL
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Sentry (monitoring des erreurs)
# ============================================
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0
# SENTRY_RELEASE=git-sha-du-deploiement
# NEXT_PUBLIC_SENTRY_RELEASE=git-sha-du-deploiement
# SENTRY_ORG=ton-org
# SENTRY_PROJECT=mathakine-frontend
# SENTRY_AUTH_TOKEN=sntrys_xxx

# ============================================
# Playwright E2E (optionnel)
# ============================================
# La suite E2E actuelle n'utilise ni globalSetup ni storageState partage par defaut.
# Les scenarios authentifies Chromium utilisent le compte de demo seed defini dans
# `frontend/lib/constants/demoLogin.ts`.
# Aucun fichier d'auth Playwright partage n'est requis dans la configuration courante.

# ============================================
# Notes
# ============================================
# - Ne jamais committer .env.local avec des secrets
# - En production, definir ces variables dans la plateforme de deploiement
# - Les variables NEXT_PUBLIC_* sont exposees au client
# - Les secrets serveur doivent rester hors du bundle client
