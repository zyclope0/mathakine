# =============================================================================
# Mathakine - Variables d'environnement
# =============================================================================
# Copiez ce fichier vers .env et ajustez les valeurs.
# Ne jamais committer .env (contient des secrets).
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données
# -----------------------------------------------------------------------------
# PostgreSQL (recommandé)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mathakine

# Tests - base séparée obligatoire
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_mathakine

# -----------------------------------------------------------------------------
# Serveur
# -----------------------------------------------------------------------------
# Port backend (frontend attend 10000 par défaut)
PORT=10000
# MATH_TRAINER_DEBUG=true
# MATH_TRAINER_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Sécurité (obligatoire en production)
# -----------------------------------------------------------------------------
# Générer : python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_long_random_string_in_production

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin : créé via BDD/scripts (ObiWan, etc.). Pas de fallback faible.
# DEFAULT_ADMIN_EMAIL=
# DEFAULT_ADMIN_PASSWORD=  # Prod : obligatoire et fort (≠ admin, password, 123456)

# -----------------------------------------------------------------------------
# Frontend (emails, CORS)
# -----------------------------------------------------------------------------
# URL du frontend Next.js
# FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=https://mathakine-frontend.onrender.com

# -----------------------------------------------------------------------------
# OpenAI - Génération IA (assistant, exercices, défis)
# -----------------------------------------------------------------------------
# Clé API OpenAI (obligatoire pour génération exercices/défis / assistant)
OPENAI_API_KEY=votre_cle_api_ici

# Source de vérité produit : code typé (app/core/app_model_policy.py, ai_generation_policy, challenge_ai_model_policy).
# Les variables ci-dessous = overrides ops ou legacy borné, pas la vérité principale.

# Assistant Maître Kine (REST/SSE) — override ops explicite. Vide = défaut produit gpt-5-mini (IA10).
# OPENAI_MODEL_ASSISTANT_CHAT_OVERRIDE=

# Legacy optionnel : si défini ET allowlisté, utilisé pour assistant_chat avant le défaut gpt-5-mini.
# Laisser vide en nominal. Ne pas utiliser gpt-3.5-turbo (ignoré avec avertissement).
# OPENAI_MODEL=

# Flux SSE « exercices IA » — override opérationnel (prioritaire sur la policy code, défaut = o3).
# Valeur doit figurer dans EXERCISES_AI_ALLOWED_MODEL_IDS (app/core/ai_generation_policy.py) sinon erreur au runtime.
OPENAI_MODEL_EXERCISES_OVERRIDE=

# Déprécié : lu seulement si OPENAI_MODEL_EXERCISES_OVERRIDE est vide (même sémantique d'override).
# OPENAI_MODEL_EXERCISES=o3

# Flux SSE « défis IA » — override ops (prioritaire sur OPENAI_MODEL_REASONING legacy si non vide).
# OPENAI_MODEL_CHALLENGES_OVERRIDE=

# Legacy défis uniquement : lu si OPENAI_MODEL_CHALLENGES_OVERRIDE est vide.
# Non activé par défaut : la vérité nominale des défis est la policy code (défaut o3).
# OPENAI_MODEL_REASONING=o3

# Défis : 2e appel si le stream o3/o3-mini est vide (allowlist). Vide = défaut policy (gpt-4o-mini).
# OPENAI_MODEL_CHALLENGES_FALLBACK_OVERRIDE=

# -----------------------------------------------------------------------------
# Emails (mot de passe oublié, vérification)
# -----------------------------------------------------------------------------
# Option A - SendGrid (prioritaire si défini)
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=noreply@mathakine.com

# Option B - SMTP (Gmail, Brevo, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=ton_email@gmail.com
# SMTP_PASSWORD=mot_de_passe_application
# SMTP_FROM_EMAIL=noreply@mathakine.com
# SMTP_USE_TLS=true

# Sans config : simulation en dev, erreur en production

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
# Sentry - erreurs et APM
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_RELEASE=git-sha-du-deploiement
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0

# -----------------------------------------------------------------------------
# Environnement
# -----------------------------------------------------------------------------
# ENVIRONMENT=development
# ENVIRONMENT=production
# MATH_TRAINER_PROFILE=dev
# LOG_LEVEL=INFO
# LOG_FILE=logs/mathakine.log

# -----------------------------------------------------------------------------
# Tests
# -----------------------------------------------------------------------------
# TESTING=true
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_mathakine
